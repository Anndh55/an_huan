# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local log & test artifacts
.next-server.log
.login-test.html
prisma-cli.cmd
src/app/_test_write.txt
src/app/_fixed.tsx

# user uploads
/public/uploads/

# dev database
prisma/dev.db
prisma/*.db

# temporary dev scripts
_*.mjs

# nested prisma artifacts
prisma/prisma/
